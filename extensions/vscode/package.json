{
  "name": "glance",
  "displayName": "Glance",
  "description": "Open large files (JSONL, CSV, logs 3GB+) without crashing",
  "version": "0.3.2",
  "publisher": "glance",
  "repository": {
    "type": "git",
    "url": "https://github.com/Velarist/glance"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:glance.fileViewer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "glance.fileViewer",
        "displayName": "Glance Large File Viewer",
        "selector": [
          {
            "filenamePattern": "*.jsonl"
          },
          {
            "filenamePattern": "*.ndjson"
          },
          {
            "filenamePattern": "*.ldjson"
          },
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.tsv"
          },
          {
            "filenamePattern": "*.log"
          },
          {
            "filenamePattern": "*.sql"
          },
          {
            "filenamePattern": "*.txt"
          },
          {
            "filenamePattern": "*.xml"
          },
          {
            "filenamePattern": "*.out"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "glance.openFile",
        "title": "Glance: Open Large File"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "glance.openFile",
          "when": "resourceExtname =~ /\\.(jsonl|ndjson|ldjson|csv|tsv|log|sql|txt|xml|out)$/"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.9.3"
  }
}
